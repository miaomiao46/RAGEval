# 数据库配置（二选一）
# 方式一：分项配置
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rag_evaluation

# 方式二：完整连接串（设置后会覆盖上面的 POSTGRES_* 配置）
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_evaluation

# JWT 密钥（生产环境务必设置固定值，否则重启后所有 token 失效）
SECRET_KEY=your-secret-key-here

# 管理员初始账号
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=adminpassword

# CORS 允许的前端地址（JSON 数组格式）
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

